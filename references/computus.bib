@incollection{mosshammer2ChronologicalSystems2008,
  title = {2 {{Chronological Systems}}},
  booktitle = {The {{Easter Computus}} and the {{Origins}} of the {{Christian Era}}},
  author = {Mosshammer, Alden A.},
