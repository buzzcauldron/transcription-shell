# Copy to `.env.docker` and set secrets. Used by docker compose / docker-run.sh.
# Do not commit `.env.docker`.

# API keys (at least one for transcription)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: match ./VERSION for image tags (docker compose build args)
# TS_VERSION=0.1.0

# Host port → container 8765 (docker compose only; see README-DOCKER.md)
# HOST_API_PORT=8765

# HTTP API inside the container (compose maps host port → this port)
TRANSCRIBER_SHELL_API_HOST=0.0.0.0
TRANSCRIBER_SHELL_API_PORT=8765

# Optional Bearer token for POST /v1/transcribe
# TRANSCRIBER_SHELL_API_KEY=

# Glyph Machina (Playwright/Chromium in container — keep headless)
TRANSCRIBER_SHELL_GM_HEADLESS=true
TRANSCRIBER_SHELL_GM_TIMEOUT_MS=120000

# Default LLM provider when CLI/API omit --provider
# TRANSCRIBER_SHELL_DEFAULT_PROVIDER=anthropic
