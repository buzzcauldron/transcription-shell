# Copy this file to .env and fill in values. Use locally only; never commit .env or push secrets.
# Design: sectioned comments (see magic-elise-tool .env.example for the same style).

# -----------------------------------------------------------------------------
# LLM API keys (set at least one for transcription)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Defaults (optional)
# -----------------------------------------------------------------------------
# Provider when CLI/API omits --provider: anthropic | openai | gemini (default: anthropic)
# TRANSCRIBER_SHELL_DEFAULT_PROVIDER=anthropic

# Single model override for the active provider (optional). Precedence: CLI --provider/--model > this > per-provider defaults below.
# TRANSCRIBER_SHELL_MODEL=

# Per-provider model ids (defaults shown; uncomment to override)
TRANSCRIBER_SHELL_ANTHROPIC_MODEL=claude-sonnet-4-20250514
TRANSCRIBER_SHELL_OPENAI_MODEL=gpt-4o
TRANSCRIBER_SHELL_GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# Protocol submodule (default: <repo>/vendor/transcription-protocol)
# TRANSCRIBER_SHELL_PROTOCOL_ROOT=

# Output root for artifacts/<job_id>/ (default: ./artifacts)
# TRANSCRIBER_SHELL_ARTIFACTS_DIR=artifacts

# -----------------------------------------------------------------------------
# Glyph Machina (browser lineation)
# -----------------------------------------------------------------------------
# Headless Chromium (default: true). Set false to watch the browser.
# TRANSCRIBER_SHELL_GM_HEADLESS=true

# Page navigation / UI timeout in ms (default: 120000)
# TRANSCRIBER_SHELL_GM_TIMEOUT_MS=120000

# TRANSCRIBER_SHELL_GM_BASE_URL=https://glyphmachina.com/

# -----------------------------------------------------------------------------
# Optional HTTP API (transcriber-shell serve)
# -----------------------------------------------------------------------------
# Bind address (default: 127.0.0.1 — not exposed on LAN)
# TRANSCRIBER_SHELL_API_HOST=127.0.0.1

# Port (default: 8765)
# TRANSCRIBER_SHELL_API_PORT=8765

# If set, require header: Authorization: Bearer <value> on /v1/*
# TRANSCRIBER_SHELL_API_KEY=
