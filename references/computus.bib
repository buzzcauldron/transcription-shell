@book{themonkbyrhtferthByrhtferthsManuscriptMS1111,
  title = {The {{Byrhtferth}}'s {{Manuscript}} ({{MS}} 17) † {{Saint John}}’s {{College}} † {{Oxford}} † [1111]},
  author = {{The Monk Byrhtferth}},
  date = {1111},
  url = {http://archive.org/details/TheByrhtferthsManuscriptms17SaintJohnsCollegeOxford},
  urldate = {2026-03-02},
  abstract = {The Byrhtferth's Manuscript (MS. 17)~ †~ Saint John’s College †~ Oxford † [1111] ~~~~~~ [written at Thorney in Cambridgeshire, circa 1110-1111] From the Thorney Computus Cambridgeshire, England; ca. 1102–10 Saint John’s College, Oxford, MS 17 Ce volume est un album de textes et de matériel graphique organisé autour de computus (littéralement, "calcul"), la science médiévale du temps du calcul et de la fixation  des dates des fêtes ecclésiastiques, en particulier de Pâques. Le  diagramme de Byrhtferth (page 8) est une méditation visuelle sur les  résonances cosmiques et religieuses du calcul, son sujet est l'harmonie  des douze mois et des quatre éléments, du temps et du monde matériel. Les tableaux montrent une série de diagrammes utilisés pour déterminer les  cycles lunaires, les jours de la semaine et les diagrammes de divination  basés sur des valeurs numériques attribuées aux lettres. ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ \textasciitilde{} \textasciitilde{} \textasciitilde{} \textasciitilde{} \textasciitilde{} \textasciitilde{} This splendid volume was created in the first decade of the 12th century at  Thorney Abbey, a Benedictine monastery in Cambridgeshire. Its importance  for the cultural and intellectual history of Anglo-Saxon and  Anglo-Norman England has been recognized since the 16th century by  historians, philologists, and scholars working in the fields of medieval  science, monastic culture, and the history of the book. St John's 17 is a compilation of texts, tables, maps and diagrams. It is  organized around the central theme of time-reckoning and calendar  construction — what in the Middle Ages was called computus. The core of computus material is surrounded by a halo of subjects which were  intimately connected with time, such as astronomy, cosmology,  geography, medicine, history, mathematics, and prognostication. It is a  superb example of a type of compilation that could be found in many  medieval cloisters and schools; but it is also unique in its dimensions,  its thoughtful arrangement, and its exquisite decoration. ~ \textasciitilde{} \textasciitilde{} \textasciitilde{} \textasciitilde{} \textasciitilde{} \textasciitilde{} This volume is an album of texts and graphic material organized around computus  (literally, “computation”), the medieval science of reckoning time and  fixing the dates of ecclesiastical feasts, particularly Easter.  Byrhtferth’s digram is a visual meditation on the cosmic and religious  resonances of computus, its subject the harmony of the twelve months and  four elements, of time and the material world. About his diagram from the Thorney Computus (page 8) , Byrhtferth said : " This figure contains the twelve signs and the two solstices and the two  equinoxes and the twice two seasons of the year; and in it are described  the four names of the elements and the names of the twelve winds and  the four ages of man. At the same time are added the twice two letters  of the name of the first man, Adam. " † Note : Afin de pouvoir exprimer votre infinie gratitude à Gracchus Dionysus pour ses années de bénévolat, l’archiviste esotériste a mis à votre disposition un lien Paypal. Faites lui un Don. ☧ Donate},
  langid = {english},
  keywords = {1111,Byrhtferth,Esotérisme,Grand Oeuvre,Hermétisme,Magie,Manuscript,MS 17,Occultisme,St John's College}
}

