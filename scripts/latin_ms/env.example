# Latin manuscript pipeline env — copy to .env.latin-ms and fill in.
# Source this file before any stage script: set -a && source .env.latin-ms && set +a
# Never commit .env.latin-ms.

# ── Job identity ──────────────────────────────────────────────────────────────
# Unique slug per batch (e.g. BNF_lat_4126_batch01).  All stage output lands at
# $LATIN_MS_WORKSPACE/jobs/$LATIN_MS_JOB_ID/.
LATIN_MS_JOB_ID=my_job_01

# Manuscript shelfmark prefix used in page filenames: {MSID}_f001r.jpg
LATIN_MS_MSID=BNF_lat_0000

# Root workspace (outside the repo).
LATIN_MS_WORKSPACE=~/latin-ms-workspace

# ── Stage 1 (strigil) ─────────────────────────────────────────────────────────
# Space-separated IIIF / HathiTrust / IA / digital-catalog URLs.
LATIN_MS_SOURCES=""

# Optional strigil flags appended verbatim (e.g. "--expected-images 120 --source iiif").
STRIGIL_FLAGS=""

# ── Stage 2 (crop / normalize) ────────────────────────────────────────────────
# Starting folio number (integer, zero-padded to 3 digits): default 1.
LATIN_MS_FOLIO_START=1
# Recto first?  "r" means image 1 = f001r, image 2 = f001v, etc.  "v" reverses.
LATIN_MS_FIRST_SIDE=r
# Target JPEG quality for normalized pages (default: 92).
LATIN_MS_JPEG_QUALITY=92
# Max long-edge in pixels — 0 to keep original size.
LATIN_MS_MAX_LONG_EDGE=0

# ── Stage 3 (lineation) ───────────────────────────────────────────────────────
# Backend: mask | kraken | glyph_machina
# mask and kraken run locally; glyph_machina requires Playwright + Chromium.
TRANSCRIBER_SHELL_LINEATION_BACKEND=mask

# Illustration masking (eynollah SBB/eynollah-image-extraction).
# Requires TensorFlow + the SavedModel at TRANSCRIBER_SHELL_EYNOLLAH_MODEL.
# When true, whited-out copies of 01_pages/ are used for lineation only.
# TRANSCRIBER_SHELL_MASK_ILLUSTRATIONS=false
# TRANSCRIBER_SHELL_EYNOLLAH_MODEL=~/eynollah_models/extract_images
# TRANSCRIBER_SHELL_MASK_DILATE=8

# Mask backend (needs latin_lineation_mvp installed — see transcription-shell README).
# TRANSCRIBER_SHELL_MASK_INFERENCE_CALLABLE=latin_lineation_mvp.infer:predict_masks
# TRANSCRIBER_SHELL_MASK_WEIGHTS_PATH=/path/to/line_mask_unet.pt

# Kraken backend.
# TRANSCRIBER_SHELL_KRAKEN_MODEL_PATH=~/src/latin_documents/model_249.mlmodel
# TRANSCRIBER_SHELL_KRAKEN_THRESHOLD=0.09
# TRANSCRIBER_SHELL_KRAKEN_MIN_LENGTH=100

# Kraken HTR recognition model (used when HTR_COMBINATION=kraken_htr).
# Set to the fine-tuned model after running s0_retrain.sh.
# TRANSCRIBER_SHELL_KRAKEN_HTR_MODEL_PATH=~/latin-ms-workspace/training/htr_latin_updated_best.mlmodel

# Glyph Machina (browser).
# TRANSCRIBER_SHELL_GM_HEADLESS=true
# TRANSCRIBER_SHELL_GM_TIMEOUT_MS=600000

# ── Stage 4 (transcription) ───────────────────────────────────────────────────
# Provider: anthropic | openai | gemini | ollama
TRANSCRIBER_SHELL_DEFAULT_PROVIDER=anthropic

# Keys — set exactly one of these (or use the matching var from your root .env).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Models (defaults below; uncomment to override).
TRANSCRIBER_SHELL_ANTHROPIC_MODEL=claude-sonnet-4-6
# TRANSCRIBER_SHELL_OPENAI_MODEL=gpt-4o
# TRANSCRIBER_SHELL_GEMINI_MODEL=gemini-2.0-flash

# Artifacts dir — stage script sets this automatically; override only if needed.
# TRANSCRIBER_SHELL_ARTIFACTS_DIR=

# Re-use existing successful YAML on rerun.
TRANSCRIBER_SHELL_SKIP_SUCCESSFUL=true

# HTR draft hint fed to the LLM.  Options: off | gm_htr | kraken_htr | parallel
# "off" is safe when lines XML already encodes baselines.
TRANSCRIBER_SHELL_HTR_COMBINATION=off

# ── Stage 5 (expand-diplomatic) ───────────────────────────────────────────────
# Backend: gemini | local (Ollama)
EXPAND_DIPLOMATIC_BACKEND=gemini
# EXPAND_DIPLOMATIC_MODEL=gemini-2.5-flash
# EXPAND_DIPLOMATIC_LOCAL_MODEL=llama3.2

# Modality: full | conservative | normalize | aggressive | local
# "full" is recommended for medieval Latin; "conservative" tends to drift on dense abbreviation.
EXPAND_DIPLOMATIC_MODALITY=full

# Number of expansion passes (default 2 — second pass catches first-pass drift)
EXPAND_DIPLOMATIC_PASSES=2

# ── Stage 6 (normalization — optional) ───────────────────────────────────────
# Editorial level: mechanical | conservative_editorial | scholarly_editorial
LATIN_MS_NORM_LEVEL=conservative_editorial
# Normalization provider (defaults to stage 4 provider if blank).
# LATIN_MS_NORM_PROVIDER=
