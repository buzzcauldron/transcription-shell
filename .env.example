# Copy this file to .env and fill in values. Use locally only; never commit .env or push secrets.
# Design: sectioned comments (see magic-elise-tool .env.example for the same style).

# -----------------------------------------------------------------------------
# LLM API keys (set at least one for transcription)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Defaults (optional)
# -----------------------------------------------------------------------------
# Provider when CLI/API omits --provider: anthropic | openai | gemini | ollama (default: anthropic)
# TRANSCRIBER_SHELL_DEFAULT_PROVIDER=anthropic

# Single model override for the active provider (optional). Precedence: CLI --provider/--model > this > per-provider defaults below.
# TRANSCRIBER_SHELL_MODEL=

# Per-provider model ids (defaults shown; uncomment to override)
TRANSCRIBER_SHELL_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Anthropic HTTP timeout (seconds) for long vision+YAML streams (default 600)
# TRANSCRIBER_SHELL_ANTHROPIC_TIMEOUT_S=600

# Extra retries after the first for 429 / 503 / 529 only (default 2)
# TRANSCRIBER_SHELL_ANTHROPIC_MAX_RETRIES=2

# Route Anthropic/OpenAI through an HTTP(S) proxy (optional; corporate networks)
# TRANSCRIBER_SHELL_LLM_USE_PROXY=false
# TRANSCRIBER_SHELL_LLM_HTTP_PROXY=http://proxy.example.com:8080

TRANSCRIBER_SHELL_OPENAI_MODEL=gpt-4o
TRANSCRIBER_SHELL_GEMINI_MODEL=gemini-2.0-flash

# Local Ollama (no cloud key; run `ollama serve` and `ollama pull llava` or another vision model)
# TRANSCRIBER_SHELL_OLLAMA_MODEL=llava
# TRANSCRIBER_SHELL_OLLAMA_BASE_URL=http://127.0.0.1:11434

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# Protocol submodule (default: <repo>/vendor/transcription-protocol)
# TRANSCRIBER_SHELL_PROTOCOL_ROOT=

# Output root for artifacts/<job_id>/ (default: ./artifacts)
# TRANSCRIBER_SHELL_ARTIFACTS_DIR=artifacts

# -----------------------------------------------------------------------------
# Lines XML gate (optional PAGE XSD; TextLine rule)
# -----------------------------------------------------------------------------
# Optional default PAGE XSD for `run` / `batch` / GUI when --xsd is not passed (needs [xml-xsd]).
# TRANSCRIBER_SHELL_LINES_XML_XSD=

# Default true: fail XML step when there are zero TextLine elements. Set false to match CLI --no-require-text-line.
# TRANSCRIBER_SHELL_XML_REQUIRE_TEXT_LINE=true

# Skip lines XML validation / optional PAGE XSD before LLM (CLI/GUI: --skip-lines-xml-validation)
# TRANSCRIBER_SHELL_SKIP_LINES_XML_VALIDATION=false

# If lineation fails (Glyph Machina, mask, Kraken, timeouts), continue to LLM without lines XML (CLI: --continue-on-lineation-failure)
# TRANSCRIBER_SHELL_CONTINUE_ON_LINEATION_FAILURE=false

# Lines XML + validation only; skip LLM (CLI/GUI: --xml-only)
# TRANSCRIBER_SHELL_XML_ONLY=false

# -----------------------------------------------------------------------------
# Lineation (default in app: glyph_machina — override to mask/kraken for local ML)
# Mask training corpus credit: https://github.com/ideasrule/latin_documents
# -----------------------------------------------------------------------------
# Training corpus (optional — for your own training jobs; not read by the app)
# Clone: ./scripts/clone-latin-documents.sh  →  docs/latin-documents-training-data.md
# LATIN_DOCUMENTS_ROOT=/path/to/latin_documents

# Full mask plugin contract: docs/mask-lineation-plugin.md
#
# TRANSCRIBER_SHELL_LINEATION_BACKEND=glyph_machina
# mask | kraken | glyph_machina
# Upstream pipeline.sh baseline: threshold=0.09, min_length=100 (run_segmenter.py default is 0.10)

# Public lab page / DOI, or a generic string if the repo URL must stay private
# TRANSCRIBER_SHELL_LINEATION_CREDIT_REPO_URL=https://github.com/ideasrule/latin_documents

# Mask backend: inference callable (private repo: pip install git+ssh://...) and/or pred .npy path
# TRANSCRIBER_SHELL_MASK_INFERENCE_CALLABLE=latin_lineation_stub.infer:predict_masks
# Example after: pip install -e "examples/latin_lineation_stub"
# Private: TRANSCRIBER_SHELL_MASK_INFERENCE_CALLABLE=your_private_pkg.infer:predict_masks

# Trained U-Net (see examples/latin_lineation_mvp/README.md): pip install -e "examples/latin_lineation_mvp"
# TRANSCRIBER_SHELL_MASK_INFERENCE_CALLABLE=latin_lineation_mvp.infer:predict_masks
# TRANSCRIBER_SHELL_MASK_WEIGHTS_PATH=/absolute/path/to/line_mask_unet.pt

# latin_lineation_mvp.infer: keep mask channels whose summed sigmoid exceeds this (pixels×probability)
# TRANSCRIBER_SHELL_MASK_CHANNEL_MIN_MASS=15

# Optional: other private checkpoint — read inside your callable via settings.mask_weights_path

# Resume training after reboot: scripts/resume-lineation-training.sh
#   LATIN_DOCUMENTS_DATA=/path/to/latin_documents/data
#   LINE_MASK_OUT=/path/to/line_mask_unet.pt   # creates line_mask_unet.train.pt for --resume auto
#   LINE_MASK_EPOCHS=100
#   LINE_MASK_DEVICE=cuda:0

# TRANSCRIBER_SHELL_MASK_PRED_NPY_PATH=/path/to/{stem}_pred.npy
# TRANSCRIBER_SHELL_MASK_DEVICE=cpu
# TRANSCRIBER_SHELL_MASK_THRESHOLD=0.5

# Kraken BLLA (pip install 'transcriber-shell[kraken]')
# TRANSCRIBER_SHELL_KRAKEN_MODEL_PATH=~/src/latin_documents/model_249.mlmodel
# Note: transfer_learned_1k_lines.mlmodel is a recognition (OCR) model — use model_249.mlmodel for lineation
# TRANSCRIBER_SHELL_KRAKEN_DEVICE=cpu
# TRANSCRIBER_SHELL_KRAKEN_THRESHOLD=0.09
# TRANSCRIBER_SHELL_KRAKEN_MIN_LENGTH=100

# -----------------------------------------------------------------------------
# Glyph Machina (browser lineation when LINEATION_BACKEND=glyph_machina)
# -----------------------------------------------------------------------------
# Before the first Playwright session each process: run `python -m playwright install chromium` (idempotent).
# Set false if browsers are preinstalled or offline (then install Chromium yourself).
# TRANSCRIBER_SHELL_GM_AUTO_INSTALL_BROWSER=true

# Headless Chromium (default: true). Set false to watch the browser.
# TRANSCRIBER_SHELL_GM_HEADLESS=true

# Page navigation / UI timeout in ms (default: 600000 — 10 min)
# TRANSCRIBER_SHELL_GM_TIMEOUT_MS=600000

# Extra pause (ms) after "Identify Lines" before waiting on download — helps the SPA finish line detection
# TRANSCRIBER_SHELL_GM_POST_IDENTIFY_WAIT_MS=15000

# TRANSCRIBER_SHELL_GM_BASE_URL=https://glyphmachina.com/

# Persistent Chromium profile for Glyph Machina (cookies / site login survive across runs)
# TRANSCRIBER_SHELL_GM_PERSISTENT_PROFILE=false
# TRANSCRIBER_SHELL_GM_USER_DATA_DIR=~/.cache/transcriber-shell/glyph-machina-browser

# -----------------------------------------------------------------------------
# Optional HTTP API (transcriber-shell serve)
# -----------------------------------------------------------------------------
# Bind address (default: 127.0.0.1 — not exposed on LAN)
# TRANSCRIBER_SHELL_API_HOST=127.0.0.1

# Port (default: 8765)
# TRANSCRIBER_SHELL_API_PORT=8765

# If set, require header: Authorization: Bearer <value> on /v1/*
# TRANSCRIBER_SHELL_API_KEY=
